sub usage() {
    my $program_name = program_name;

    my $usage = << "EOF";
Usage: $program_name [options] tex_file_1 tex_file_2 ...

Remove all comments from the supplied .tex files. If successful, replaces the
original .tex file by the rewritten file. Fails if either the original or the
rewritten file can't be LaTeXed.

Options:
    -novalidate:     Skip LaTeX validation.

    -nopreamble:     Don't remove explicit comment characters until 
                     \\begin{document}.

    -nobibliography: Don't remove explicit comment characters in the 
                     bibligraphy.

    -inprod:         Don't remove explicit comment characters in the
                     preamble or the bibliography; equivalent to
                     -nopreamble -nobibliography.

    -noconditionals: Don't remove dubious conditionals.

    -nomacros:       Don't remove macros used as comments.

    -noclean:        Don't remove intermediate files (.aux, .log, .dvi, etc.)
                     
    -noreplace:      Even if the conversion is successful, don't replace the
                     original file.
                     
    -nosvn:          Don't perform SVN operations.
                     
    -help:           Print this.
                     
    -quit:           Less output.
                     
    -verbose:        More ouput.
                     
    -debug:          Much more output.
EOF
    
    $LOG->notify($usage);

    exit 1;
}

