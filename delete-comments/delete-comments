program_banner();

GetOptions("validate!"     => \$OPT{validate},
           "preamble!"     => \$OPT{preamble},
           "bibliography!" => \$OPT{bibliography},
           "inprod"        => \$OPT{inprod},
           "conditionals!" => \$OPT{conditionals},
           "macros!"       => \$OPT{macros},
           "protection!"   => \$OPT{protected},
           "svn!"          => \$OPT{do_svn},
           "clean!"        => \$OPT{do_clean},
           "replace!"      => \$OPT{do_replace},
           "help"          => \&usage,
           "verbose!"      => sub { $LOG->set_verbose($_[1]) },
           "quiet!"        => sub { $LOG->set_quiet($_[1]) },
           "debug!"        => sub { $LOG->set_debug($_[1]) },
) or usage;

usage unless @ARGV;

for my $tex_file (@ARGV) {
    my $in_file = resolve_tex_filename($tex_file);

    if (! defined $in_file) {
        $LOG->error("Can't find $tex_file; skipping...\n\n");

        next;
    }
    
    eval { process_file($in_file) };
    
    if ($@) {
        $LOG->notify("\nUnable to process '$tex_file': $@\n");

        $LOG->notify("\nSkipping '$tex_file'\n");

        next;
    }
}

